# Copy to apps/daemon/.env and fill in. Never commit the real .env.

# Shared secret the watch sends as: Authorization: Bearer <token>
# Generate one, e.g.: openssl rand -hex 32
CLAUDEWATCH_TOKEN=replace-with-a-long-random-token

# Port the daemon listens on (Cloudflare tunnel points here).
PORT=8787

# Root of Claude Code session history. Override only for testing.
CLAUDE_PROJECTS_DIR=~/.claude/projects
