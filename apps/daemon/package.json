{
  "name": "@claudewatch/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ClaudeWatch daemon: reads Claude Code session history and serves the frozen /sessions contract.",
  "scripts": {
    "list": "tsx src/list.ts",
    "serve": "tsx --env-file-if-exists=.env src/serve.ts",
    "start": "tsx --env-file-if-exists=.env src/serve.ts",
    "test": "node --import tsx --test test/*.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "ajv": "^8.17.1",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
